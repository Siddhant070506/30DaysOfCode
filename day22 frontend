<!DOCTYPE html>
<html lang="en" style="scroll-behavior:smooth;">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Siddhant | Advanced Portfolio</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial, sans-serif;
}

body{
    background:#0f172a;
    color:white;
    transition:0.4s;
}

.light{
    background:#f8fafc;
    color:#0f172a;
}

nav{
    position:fixed;
    width:100%;
    display:flex;
    justify-content:space-between;
    padding:20px 10%;
    backdrop-filter:blur(10px);
    background:rgba(0,0,0,0.4);
    z-index:1000;
}

.light nav{
    background:rgba(255,255,255,0.6);
}

nav h2{
    letter-spacing:2px;
}

nav button{
    padding:6px 14px;
    border:none;
    cursor:pointer;
    font-weight:bold;
}

section{
    min-height:100vh;
    padding:120px 10%;
    display:flex;
    flex-direction:column;
    justify-content:center;
}

.hero{
    background:linear-gradient(135deg,#0f172a,#1e293b,#0f172a);
}

.hero h1{
    font-size:50px;
}

.hero span{
    color:#38bdf8;
}

.btn{
    margin-top:20px;
    padding:10px 25px;
    background:#38bdf8;
    border:none;
    cursor:pointer;
    font-weight:bold;
}

.skills .bar{
    margin:20px 0;
}

.progress{
    width:100%;
    background:#334155;
    height:8px;
    border-radius:10px;
    overflow:hidden;
}

.progress span{
    display:block;
    height:100%;
    width:0%;
    background:#38bdf8;
    transition:2s;
}

.projects{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
    gap:20px;
    margin-top:30px;
}

.card{
    background:#1e293b;
    padding:20px;
    border-radius:10px;
    transition:0.4s;
}

.light .card{
    background:white;
}

.card:hover{
    transform:translateY(-10px);
}

.reveal{
    opacity:0;
    transform:translateY(40px);
    transition:1s;
}

.reveal.active{
    opacity:1;
    transform:translateY(0);
}

footer{
    text-align:center;
    padding:30px;
}
</style>
</head>

<body>

<nav>
<h2>Siddhant</h2>
<button onclick="toggleTheme()">Theme</button>
</nav>

<section class="hero reveal">
<h1>Hi, I'm Siddhant 👋</h1>
<h2>I am a <span id="typing"></span></h2>
<button class="btn" onclick="scrollToSection('projects')">View Work</button>
</section>

<section class="skills reveal">
<h2>Skills</h2>

<div class="bar">
<p>C++ / DSA</p>
<div class="progress"><span data-width="90%"></span></div>
</div>

<div class="bar">
<p>Frontend</p>
<div class="progress"><span data-width="80%"></span></div>
</div>

<div class="bar">
<p>Problem Solving</p>
<div class="progress"><span data-width="85%"></span></div>
</div>

</section>

<section id="projects" class="reveal">
<h2>Projects</h2>
<div class="projects">
<div class="card">DSA Tracker</div>
<div class="card">Weather App</div>
<div class="card">Animated Portfolio</div>
</div>
</section>

<footer>
© 2026 Siddhant Raghuvanshi
</footer>

<script>

// Theme Toggle
function toggleTheme(){
    document.body.classList.toggle("light");
}

// Typing Effect
const words=["C++ Developer","DSA Enthusiast","Frontend Developer","Problem Solver"];
let i=0,j=0,isDeleting=false;

function type(){
    let current=words[i];
    
    if(!isDeleting){
        document.getElementById("typing").textContent=current.slice(0,++j);
        if(j===current.length){
            isDeleting=true;
            setTimeout(type,1000);
            return;
        }
    }else{
        document.getElementById("typing").textContent=current.slice(0,--j);
        if(j===0){
            isDeleting=false;
            i=(i+1)%words.length;
        }
    }
    setTimeout(type,100);
}
type();

// Scroll Reveal
function reveal(){
    document.querySelectorAll(".reveal").forEach(sec=>{
        if(sec.getBoundingClientRect().top < window.innerHeight-100){
            sec.classList.add("active");
        }
    });
}
window.addEventListener("scroll",reveal);
reveal();

// Progress Bar Animation
window.addEventListener("scroll",()=>{
    document.querySelectorAll(".progress span").forEach(bar=>{
        if(bar.getBoundingClientRect().top < window.innerHeight-50){
            bar.style.width=bar.getAttribute("data-width");
        }
    });
});

// Smooth Scroll
function scrollToSection(id){
    document.getElementById(id).scrollIntoView();
}

</script>

</body>
</html>
