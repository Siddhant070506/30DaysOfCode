<!DOCTYPE html>
<html lang="en" style="scroll-behavior:smooth;">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Siddhant | Dark Knight Developer</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family: 'Poppins', sans-serif;
}

body{
    background:#0a0a0a;
    color:#ff2e2e;
    overflow-x:hidden;
    cursor:none;
}

/* Floating particles */
body::before{
    content:"";
    position:fixed;
    width:100%;
    height:100%;
    background:url("https://www.transparenttextures.com/patterns/stardust.png");
    opacity:0.08;
    z-index:-2;
}

/* Batman Background Logo */
.bg-logo{
    position:fixed;
    top:50%;
    left:50%;
    transform:translate(-50%,-50%);
    width:700px;
    opacity:0.04;
    z-index:-1;
    animation:pulse 6s infinite ease-in-out;
}

@keyframes pulse{
    0%{opacity:0.03;}
    50%{opacity:0.07;}
    100%{opacity:0.03;}
}

/* Navbar */
nav{
    position:fixed;
    width:100%;
    display:flex;
    justify-content:space-between;
    padding:20px 10%;
    background:rgba(0,0,0,0.6);
    backdrop-filter:blur(10px);
    border-bottom:1px solid #ff2e2e;
    z-index:1000;
}

nav h1{color:white;}
nav ul{
    list-style:none;
    display:flex;
    gap:30px;
}
nav ul li a{
    text-decoration:none;
    color:#ff2e2e;
    transition:0.3s;
}
nav ul li a:hover{color:white;}

/* Hero */
.hero{
    height:100vh;
    display:flex;
    flex-direction:column;
    justify-content:center;
    align-items:center;
    text-align:center;
}

.hero h2{
    font-size:50px;
    color:white;
}

.typing{
    color:#ff2e2e;
    text-shadow:0 0 15px #ff2e2e;
}

/* Fire Glow Button */
.btn{
    margin-top:30px;
    padding:12px 35px;
    background:#ff2e2e;
    border:none;
    font-weight:bold;
    cursor:pointer;
    transition:0.3s;
}

.btn:hover{
    background:black;
    color:#ff2e2e;
    box-shadow:0 0 25px #ff2e2e, 0 0 50px red;
}

/* Sections */
.section{
    padding:100px 10%;
}

.section h3{
    font-size:28px;
    margin-bottom:30px;
    border-left:5px solid #ff2e2e;
    padding-left:10px;
}

/* Cards */
.cards{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
    gap:25px;
}

.card{
    background:#111;
    padding:25px;
    transition:0.4s;
    border:1px solid transparent;
}

.card:hover{
    transform:translateY(-10px);
    border:1px solid #ff2e2e;
    box-shadow:0 0 20px #ff2e2e;
}

/* Scroll Reveal */
.reveal{
    opacity:0;
    transform:translateY(80px);
    transition:1s;
}

.reveal.active{
    opacity:1;
    transform:translateY(0);
}

/* Footer */
footer{
    text-align:center;
    padding:30px;
    background:#111;
    border-top:1px solid #ff2e2e;
}

/* Custom Cursor */
.cursor{
    position:fixed;
    width:20px;
    height:20px;
    border-radius:50%;
    background:#ff2e2e;
    pointer-events:none;
    transform:translate(-50%,-50%);
    box-shadow:0 0 20px #ff2e2e, 0 0 40px #ff2e2e;
    z-index:9999;
}

@media(max-width:768px){
    .hero h2{font-size:35px;}
}
</style>
</head>

<body>

<div class="cursor"></div>

<svg class="bg-logo" viewBox="0 0 512 512">
<path fill="#ff2e2e" d="M256 64c-44 0-72 48-96 48-16 0-32-16-48-16 0 32 16 64 16 96 0 48-48 64-48 128 32-16 80-16 128 0 48-16 96-16 128 0 0-64-48-80-48-128 0-32 16-64 16-96-16 0-32 16-48 16-24 0-52-48-96-48z"/>
</svg>

<nav>
<h1>🦇 Siddhant</h1>
<ul>
<li><a href="#home">Home</a></li>
<li><a href="#skills">Skills</a></li>
<li><a href="#projects">Projects</a></li>
</ul>
</nav>

<section id="home" class="hero">
<h2>I Am <span class="typing"></span></h2>
<button class="btn">Download Resume</button>
</section>

<section id="skills" class="section reveal">
<h3>⚡ Skills</h3>
<div class="cards">
<div class="card">C++ & DSA</div>
<div class="card">Verilog & VLSI</div>
<div class="card">IoT Systems</div>
<div class="card">Frontend Development</div>
</div>
</section>

<section id="projects" class="section reveal">
<h3>🛠 Projects</h3>
<div class="cards">
<div class="card">30 Days Coding Challenge</div>
<div class="card">Batman Portfolio</div>
<div class="card">IoT Smart Device</div>
</div>
</section>

<footer>
© 2026 Siddhant Raghuvanshi | Gotham Mode 🦇
</footer>

<script>

/* Typing Effect */
const text = "The Dark Knight Developer";
let index = 0;
function type(){
    if(index < text.length){
        document.querySelector(".typing").innerHTML += text.charAt(index);
        index++;
        setTimeout(type,80);
    }
}
type();

/* Scroll Reveal */
window.addEventListener("scroll", function(){
    let reveals = document.querySelectorAll(".reveal");
    for(let i=0;i<reveals.length;i++){
        let windowHeight = window.innerHeight;
        let elementTop = reveals[i].getBoundingClientRect().top;
        if(elementTop < windowHeight - 150){
            reveals[i].classList.add("active");
        }
    }
});

/* Custom Cursor */
const cursor = document.querySelector(".cursor");
document.addEventListener("mousemove", (e)=>{
    cursor.style.left = e.clientX + "px";
    cursor.style.top = e.clientY + "px";
});

</script>

</body>
</html>
