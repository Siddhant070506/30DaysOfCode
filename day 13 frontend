<!DOCTYPE html>
<html lang="en" style="scroll-behavior:smooth;">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Siddhant | Dark Knight Developer</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family: 'Poppins', sans-serif;
}

body{
    background:#0a0a0a;
    color:#ff2e2e;
    overflow-x:hidden;
    cursor:none;
}

/* ===== BATMAN BACKGROUND LOGO ===== */
.bg-logo{
    position:fixed;
    top:50%;
    left:50%;
    transform:translate(-50%,-50%);
    width:700px;
    opacity:0.05;
    z-index:-1;
    animation:pulse 6s infinite ease-in-out;
}

@keyframes pulse{
    0%{opacity:0.04;}
    50%{opacity:0.08;}
    100%{opacity:0.04;}
}

/* ===== NAVBAR ===== */
nav{
    position:fixed;
    width:100%;
    display:flex;
    justify-content:space-between;
    padding:20px 10%;
    background:rgba(0,0,0,0.6);
    backdrop-filter:blur(10px);
    border-bottom:1px solid #ff2e2e;
    z-index:1000;
}

nav h1{
    color:white;
    letter-spacing:2px;
}

nav ul{
    list-style:none;
    display:flex;
    gap:30px;
}

nav ul li{
    cursor:pointer;
    transition:0.3s;
}

nav ul li:hover{
    color:white;
}

/* ===== HERO ===== */
.hero{
    height:100vh;
    display:flex;
    flex-direction:column;
    justify-content:center;
    align-items:center;
    text-align:center;
}

.hero h2{
    font-size:55px;
    color:white;
}

.hero span{
    color:#ff2e2e;
    text-shadow:0 0 15px #ff2e2e;
}

.btn{
    margin-top:30px;
    padding:12px 35px;
    background:#ff2e2e;
    border:none;
    font-weight:bold;
    cursor:pointer;
    box-shadow:0 0 15px #ff2e2e;
    transition:0.3s;
}

.btn:hover{
    background:black;
    color:#ff2e2e;
    border:1px solid #ff2e2e;
}

/* ===== SECTIONS ===== */
.section{
    padding:100px 10%;
}

.section h3{
    font-size:30px;
    margin-bottom:30px;
    border-left:5px solid #ff2e2e;
    padding-left:10px;
}

.cards{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
    gap:25px;
}

.card{
    background:#111;
    padding:25px;
    transition:0.4s;
}

.card:hover{
    transform:translateY(-10px);
    box-shadow:0 0 25px #ff2e2e;
}

/* ===== SCROLL REVEAL ===== */
.reveal{
    opacity:0;
    transform:translateY(80px);
    transition:all 1s ease;
}

.reveal.active{
    opacity:1;
    transform:translateY(0);
}

/* ===== FOOTER ===== */
footer{
    text-align:center;
    padding:30px;
    background:#111;
    border-top:1px solid #ff2e2e;
}

/* ===== GLOW CURSOR ===== */
.cursor{
    position:fixed;
    width:20px;
    height:20px;
    border-radius:50%;
    background:#ff2e2e;
    pointer-events:none;
    transform:translate(-50%,-50%);
    box-shadow:0 0 20px #ff2e2e, 0 0 40px #ff2e2e;
    z-index:9999;
}
</style>
</head>

<body>

<!-- Custom Cursor -->
<div class="cursor"></div>

<!-- Batman SVG Logo -->
<svg class="bg-logo" viewBox="0 0 512 512">
<path fill="#ff2e2e" d="M256 64c-44 0-72 48-96 48-16 0-32-16-48-16 0 32 16 64 16 96 0 48-48 64-48 128 32-16 80-16 128 0 48-16 96-16 128 0 0-64-48-80-48-128 0-32 16-64 16-96-16 0-32 16-48 16-24 0-52-48-96-48z"/>
</svg>

<nav>
    <h1>🦇 Siddhant</h1>
    <ul>
        <li><a href="#home" style="color:inherit;text-decoration:none;">Home</a></li>
        <li><a href="#skills" style="color:inherit;text-decoration:none;">Skills</a></li>
        <li><a href="#projects" style="color:inherit;text-decoration:none;">Projects</a></li>
    </ul>
</nav>

<section id="home" class="hero">
    <h2>I Am <span>The Dark Knight Developer</span></h2>
    <button class="btn">Download Resume</button>
</section>

<section id="skills" class="section reveal">
    <h3>⚡ Skills</h3>
    <div class="cards">
        <div class="card">C++ & DSA</div>
        <div class="card">Verilog & Digital Design</div>
        <div class="card">IoT Systems</div>
        <div class="card">Frontend Development</div>
    </div>
</section>

<section id="projects" class="section reveal">
    <h3>🛠 Projects</h3>
    <div class="cards">
        <div class="card">30 Days Coding Challenge</div>
        <div class="card">Batman Themed Portfolio</div>
        <div class="card">Smart IoT Device</div>
    </div>
</section>

<footer>
© 2026 Siddhant Raghuvanshi | Gotham Mode 🦇
</footer>

<script>

/* Scroll Reveal */
window.addEventListener("scroll", function(){
    let reveals = document.querySelectorAll(".reveal");
    for(let i=0;i<reveals.length;i++){
        let windowHeight = window.innerHeight;
        let elementTop = reveals[i].getBoundingClientRect().top;
        if(elementTop < windowHeight - 150){
            reveals[i].classList.add("active");
        }
    }
});

/* Glow Cursor */
const cursor = document.querySelector(".cursor");
document.addEventListener("mousemove", (e)=>{
    cursor.style.left = e.clientX + "px";
    cursor.style.top = e.clientY + "px";
});

</script>

</body>
</html>
