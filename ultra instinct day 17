<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Siddhant | Ultra Instinct</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial, Helvetica, sans-serif;
}

body{
    background:black;
    color:white;
    overflow-x:hidden;
}

/* ===== HERO SECTION ===== */
.hero{
    height:100vh;
    display:flex;
    flex-direction:column;
    justify-content:center;
    align-items:center;
    text-align:center;
    position:relative;
    overflow:hidden;
}

/* ===== GOKU BACKGROUND ===== */
.hero::before{
    content:"";
    position:absolute;
    inset:0;
    background:url("goku.png") center/cover no-repeat;
    opacity:0.35;
    z-index:-3;
    animation:breathe 6s ease-in-out infinite;
}

/* Breathing Animation */
@keyframes breathe{
    0%{ transform:scale(1); }
    50%{ transform:scale(1.05); }
    100%{ transform:scale(1); }
}

/* ===== ULTRA INSTINCT AURA ===== */
.hero::after{
    content:"";
    position:absolute;
    inset:0;
    background:radial-gradient(circle at center, rgba(0,255,255,0.5), transparent 60%);
    z-index:-2;
    animation:aura 3s infinite alternate;
}

@keyframes aura{
    from{
        opacity:0.4;
        filter:blur(20px);
    }
    to{
        opacity:0.9;
        filter:blur(50px);
    }
}

/* ===== GLOWING EYES EFFECT ===== */
.eye-glow{
    position:absolute;
    top:38%;
    left:50%;
    width:140px;
    height:50px;
    transform:translateX(-50%);
    background:radial-gradient(circle, cyan 10%, transparent 70%);
    filter:blur(18px);
    animation:eyePulse 1.5s infinite alternate;
    pointer-events:none;
}

@keyframes eyePulse{
    from{ opacity:0.6; }
    to{ opacity:1; }
}

/* ===== HEADING ===== */
.hero h1{
    font-size:60px;
    color:cyan;
    text-shadow:0 0 25px cyan;
    z-index:1;
}

.hero p{
    margin-top:20px;
    max-width:600px;
    opacity:0.8;
    z-index:1;
}

/* ===== BUTTON ===== */
.btn{
    margin-top:30px;
    padding:15px 35px;
    border:none;
    border-radius:30px;
    background:cyan;
    color:black;
    font-weight:bold;
    cursor:pointer;
    box-shadow:0 0 20px cyan;
    transition:0.3s;
    z-index:1;
}

.btn:hover{
    transform:scale(1.05);
    box-shadow:0 0 50px cyan;
}

/* ===== NAVBAR ===== */
nav{
    position:fixed;
    top:20px;
    right:50px;
}

nav a{
    color:white;
    margin-left:20px;
    text-decoration:none;
}

nav a:hover{
    color:cyan;
}

.logo{
    position:fixed;
    top:20px;
    left:40px;
    font-size:22px;
    color:cyan;
    text-shadow:0 0 15px cyan;
}
</style>
</head>

<body>

<div class="logo">Siddhant</div>

<nav>
    <a href="#">Home</a>
    <a href="#">Projects</a>
    <a href="#">Contact</a>
</nav>

<section class="hero">
    <div class="eye-glow"></div>
    <h1>Ultra Instinct Mode ⚡</h1>
    <p>Grinding DSA & building powerful frontend experiences every single day.</p>
    <button class="btn">Download Resume</button>
</section>

</body>
</html>
